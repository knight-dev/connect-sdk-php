{
    "name": "logicware/connect-sdk",
    "description": "Official PHP SDK for Logicware Connect \u2014 integrate your own courier website with a Logicware-hosted warehouse.",
    "type": "library",
    "license": "MIT",
    "keywords": ["logicware", "connect", "sdk", "courier", "shipping", "freight", "caribbean"],
    "homepage": "https://logicware.app/developers/sdk-php",
    "support": {
        "issues": "https://github.com/knight-dev/connect-sdk-php/issues",
        "source": "https://github.com/knight-dev/connect-sdk-php"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.8",
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12",
        "friendsofphp/php-cs-fixer": "^3.65"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Default HTTP client implementation. Any PSR-18 client works."
    },
    "autoload": {
        "psr-4": {
            "Logicware\\Connect\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Logicware\\Connect\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=1G",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
